{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AzureSql": ""
  },
  "Upload": {
    "MaxFileSizeBytes": 20971520,
    "MaxBatchSizeBytes": 26214400,
    "AllowedExtensions": [ ".pdf", ".docx", ".xlsx", ".png", ".jpg", ".jpeg" ],
    "AllowedMimeTypes": [
      "application/pdf",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "image/png",
      "image/jpeg"
    ]
  },
  "N8N": {
    "WebhookUrl": "",
    "TimeoutSeconds": 15,
    "SharedSecret": ""
  },
  "Blob": {
    "ConnectionString": "",
    "ContainerName": "school-archives",
    "UploadTimeoutSeconds": 30,
    "SasTtlMinutes": 10
  },
  "LocalDev": {
    "DownloadStreamEnabled": false
  },
  "Auth": {
    "Issuer": "",
    "Audience": "",
    "SigningKey": "",
    "RequireHttpsMetadata": true,
    "ClockSkewSeconds": 30,
    "DevBypassEnabled": false
  },
  "RateLimit": {
    "Enabled": true,
    "UploadPerMinute": 30,
    "ReadPerMinute": 300,
    "CleanupIntervalSeconds": 60,
    "IdleEntryTtlSeconds": 600
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowCredentials": false,
    "AllowedMethods": [ "GET", "POST", "OPTIONS" ],
    "AllowedHeaders": [ "Authorization", "Content-Type", "X-Dev-School-Id", "X-Dev-User-Id" ],
    "PreflightMaxAgeSeconds": 600
  },
  "Subscriptions": {
    "Enabled": true,
    "DefaultGracePeriodDays": 7,
    "Schools": []
  }
}
