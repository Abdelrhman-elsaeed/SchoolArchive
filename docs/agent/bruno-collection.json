      "type": "http",
      "method": "GET",
      "url": "{{baseUrl}}/health",
      "seq": 1
    },
    {
      "name": "Upload (no auth) - expect 401",
      "type": "http",
      "method": "POST",
      "url": "{{baseUrl}}/api/v1/archive/upload",
      "headers": [],
      "body": {
        "type": "multipart/form-data",
        "file": "@file(sample.pdf)"
      },
      "seq": 2
    },
